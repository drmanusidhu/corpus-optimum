# Manu's AI Coaching Agent - Environment Variables
# Copy this to .env and fill in your credentials

# Oura Ring API
# Get from: cloud.ouraring.com/personal-access-tokens
OURA_PERSONAL_ACCESS_TOKEN=your_oura_pat_here

# Anthropic Claude API
# Get from: console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Telegram Bot
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Notion Workspace
# Get from: notion.so/my-integrations
NOTION_API_KEY=secret_your_notion_key_here

# Notion Database IDs (from URLs)
# Tasks database: https://notion.so/[YOUR_WORKSPACE]/[THIS_ID]?v=...
NOTION_TASKS_DB_ID=1c9aa925b9f681ad8085d1b16c0e3785

# My Day page ID
NOTION_MY_DAY_PAGE_ID=1c9aa925b9f681a99ddde2714bac1344

# Google Calendar
# Get credentials.json from: console.cloud.google.com
# Create OAuth 2.0 Desktop app credentials
GOOGLE_CREDENTIALS_PATH=./credentials.json
